// Towers of Hanoi — count moves via exponential double recursion. hanoi(n)=2^n-1.
fn add(a: int, b: int) -> int = a + b
fn sub(a: int, b: int) -> int = a - b
fn hanoi(n: int, acc: int) -> int = match n {
    0 => acc
    _ => hanoi(sub(n, 1), add(hanoi(sub(n, 1), acc), 1))
}
print("${hanoi(25, 0)}")
