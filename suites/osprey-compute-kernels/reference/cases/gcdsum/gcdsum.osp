// Sum of gcd(i, K) for i in 1..N — Euclidean-algorithm recursion (modulo heavy).
fn add(a: int, b: int) -> int = a + b
fn mod_(a: int, b: int) -> int = a % b

fn gcd(a: int, b: int) -> int = match b {
    0 => a
    _ => gcd(b, mod_(a, b))
}
fn step(acc: int, i: int) -> int = add(acc, gcd(i, 1234567))

print("${range(1, 2000000) |> fold(0, step)}")
