// Mutually-recursive isEven/isOdd applied across a range — classic mutual recursion.
fn add(a: int, b: int) -> int = a + b
fn sub(a: int, b: int) -> int = a - b
fn mod_(a: int, b: int) -> int = a % b
fn isEven(n: int) -> bool = match n { 0 => true  _ => isOdd(sub(n, 1)) }
fn isOdd(n: int)  -> bool = match n { 0 => false _ => isEven(sub(n, 1)) }
fn step(acc: int, i: int) -> int = match isEven(mod_(i, 1000)) { true => add(acc, 1)  false => acc }
print("${range(1, 130000) |> fold(0, step)}")
