// Sum of decimal digit-sums over 1..N — integer division (n/10) and modulo in recursion.
fn add(a: int, b: int) -> int = a + b
fn mod_(a: int, b: int) -> int = a % b
fn div10(n: int) -> int = intDiv(n, 10)

fn digsum(n: int) -> int = match (n < 10) {
    true  => n
    false => add(mod_(n, 10), digsum(div10(n)))
}
fn step(acc: int, i: int) -> int = add(acc, digsum(i))
print("${range(1, 2000001) |> fold(0, step)}")
